{
    "name": "lattice/scheduler",
    "description": "Task scheduling system for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "scheduler",
        "cron",
        "task-scheduling",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/scheduler"
    },
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Scheduler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Scheduler\\Tests\\": "tests/"
        }
    }
}
